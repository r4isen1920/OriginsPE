{
    "format_version": "1.10.0",
    "particle_effect": {
        "description": {
            "identifier": "r4isen1920_originspe:electric_zap",
            "basic_render_parameters": {
                "material": "particles_blend",
                "texture": "textures/origins/particles/glow_fireworks"
            }
        },
        "curves": {
            "variable.opacity": {
                "type": "bezier",
                "input": "v.particle_age",
                "horizontal_range": "v.particle_lifetime",
                "nodes": [0, 1, 0.2, 0]
            }
        },
        "components": {
            "minecraft:emitter_rate_instant": {
                "num_particles": 4
            },
            "minecraft:emitter_lifetime_once": {
                "active_time": 0.05
            },
            "minecraft:emitter_shape_box": {
                "offset": [0, 0.2, 0],
                "half_dimensions": [0.05, 0.1, 0.05],
                "direction": "outwards"
            },
            "minecraft:particle_lifetime_expression": {
                "max_lifetime": "math.random(0.08, 0.2)"
            },
            "minecraft:particle_initial_spin": {
                "rotation": "math.random(0, 360)"
            },
            "minecraft:particle_initial_speed": 1.5,
            "minecraft:particle_motion_dynamic": {
                "linear_acceleration": ["math.random(-4, 4)", "math.random(-2, 2)", "math.random(-4, 4)"],
                "linear_drag_coefficient": 6.0
            },
            "minecraft:particle_appearance_billboard": {
                "size": ["(0.22*(v.particle_random_1+0.2))", "(0.22*(v.particle_random_1+0.2))"],
                "facing_camera_mode": "lookat_xyz",
                "uv": {
                    "texture_width": 256,
                    "texture_height": 30,
                    "flipbook": {
                        "base_UV": [0, 0],
                        "size_UV": [32, 30],
                        "step_UV": [32, 0],
                        "max_frame": 8,
                        "stretch_to_lifetime": true
                    }
                }
            },
            "minecraft:particle_appearance_tinting": {
                "color": {
                    "interpolant": "v.particle_age / v.particle_lifetime",
                    "gradient": {
                        "0.0": "#FFFFFFFA",
                        "0.2": "#FF4BE6FF",
                        "1.0": "#00000000"
                    }
