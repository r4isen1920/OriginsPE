	//---------------------------------------------------------------------------
	// Vanilla Modifications
	//---------------------------------------------------------------------------


	"npc_screen_render_index@common.empty_panel": {
		"controls": [
			{
				"custom@npc_screen_contents_custom": {
					"bindings": [
						{
							"binding_name": "#dialogtext",
							"binding_type": "global"
						},
						{
							"binding_type": "view",
							"source_property_name": "('%.4s' * #dialogtext = '_op:')",
							"target_property_name": "#visible"
						}
					]
				}
			},

			{
				"vanilla@origin_common.factory_condition": {
					"$target_name": "vanilla_npc_screen",
					"$target_control": "npc_interact.npc_screen_contents",

					"$condition": "((not ('%.4s' * #dialogtext = '_op:')) * 1)"
				}
			}
		]
	},

	"npc_screen_contents_custom@common.empty_panel": {
		"size": ["100%", "100%"],

		"controls": [
			{
				"foreground@common.empty_panel": {
					"size": ["100%", "100%"],
					"layer": 2,

					"controls": [
						{ "picker_screen@origin_picker_screen_npc.root": {} },
						{ "options@origin_options_screen.root": {} },
						{ "welcome_screen@origin_welcome_screen.root": {} },
						{ "ability_selector@origin_ability_wheel_npc.root": {} }
					]
				}
			},

			{
				"background": {
					"type": "image",
					"size": ["100%", "100%"],
					"texture": "textures/ui/White",
					"color": [0.0, 0.0, 0.0],
					"alpha": 0.6,
					"layer": 1,

					"bindings": [
						{
							"binding_name": "#dialogtext",
							"binding_type": "global"
						},
						{
							"binding_type": "view",
							"source_property_name": "(not ('%.7s' * #dialogtext = '_op:abw'))",
							"target_property_name": "#visible"
						}
					]
				}
			}
		]
	},




	//---------------------------------------------------------------------------
	// Main
	//---------------------------------------------------------------------------


	"npc_screen@common.base_screen": {
		"$screen_content": "npc_interact.npc_screen_render_index",

		"$screen_animations": [],
		"$background_animations": [],
		"$use_loading_bars": true,

		"force_render_below": true,
		"cache_screen": true,
		"close_on_player_hurt": false,

		"button_mappings": [
			{
				"from_button_id": "button.menu_exit",
				"to_button_id": "button.menu_continue",
				"mapping_type": "global"
			}
		]
	}
}
