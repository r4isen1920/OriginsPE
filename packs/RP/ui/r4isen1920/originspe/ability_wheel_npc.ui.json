{
	/* UI developed by r4isen1920 | Under MIT LICENSE */

	/*
		Input-only layer. The wheel VISUALS render on the HUD title.
	*/

	"namespace": "origin_ability_wheel_npc",




	//---------------------------------------------------------------------------
	// Hitbox
	//---------------------------------------------------------------------------


	"hitbox@origin_common.hori_stack": {
		"$slot_index|default": 1,

		"size": ["100%", "100%"],

		"collection_name": "student_buttons_collection",

		"controls": [
			{
				"click@origin_common.origin_selector_button": {
					"collection_index": "$slot_index",

					"size": ["100%", "100%"],
					"alpha": 0.0,
					"propagate_alpha": true,

					"$visible_binding": "(#student_button_text = #student_button_text)", // required

					"$button_sound_effect_name": "none",
					"$button_sound_effect_volume": 0.0,

					"$default_button_texture": "textures/none",
					"$hover_button_texture": "textures/none",
					"$pressed_button_texture": "textures/none"
				}
			}
		]
	},

	"hitbox_holder@common.empty_panel": {
		"$hit_size|default": [42, 42],
		"$slot_offset|default": [0, 0],

		"size": "$hit_size",
		"offset": "$slot_offset",

		"controls": [
			{ "hitbox@hitbox": {} },
			{ "tooltip@hitbox_tooltip_key": {} }
		]
	},




	//---------------------------------------------------------------------------
	// Tooltip Key Helpers
	//---------------------------------------------------------------------------


	"hitbox_tooltip_key@common.empty_panel": {
		"$slot_tooltip_anchor|default": "center",
		"$slot_tooltip_offset|default": [0, 0],

		"anchor_from": "$slot_tooltip_anchor",
		"anchor_to": "$slot_tooltip_anchor",
		"size": ["100%cm", "100%cm"],
		"offset": "$slot_tooltip_offset",

		"ignored": "$touch",

		"controls": [
			{
				"non_bind_bg": {
					"type": "image",
					"texture": "textures/ui/keyboard_tooltip_icon",
					"size": [17, 17],

					"$layer|default": 7,
					"layer": "$layer",

					"controls": [
						{
							"text_icon": {
								"type": "label",
								"max_size": ["100%", "100%"],
								"offset": [0.1, -1.5],
								"text": "(('§z' + (1 + ($button_type - 'slot_'))))",
								"shadow": false,
								"layer": "$layer"
							}
						}
					],

					"bindings": [
						{
							"binding_type": "global",
							"binding_name": "(not #gamepad_helper_visible)",
							"binding_name_override": "#visible"
						}
					]
				}
			},
			{
				"bind_icon@common.gamepad_icon_button": {
					"variables": [
						{ "requires": "($button_type = 'slot_0')", "$icon_texture": "#controller_face_up_icon" },
						{ "requires": "($button_type = 'slot_1')", "$icon_texture": "#controller_dpad_up_icon" },
						{ "requires": "($button_type = 'slot_2')", "$icon_texture": "#controller_dpad_right_icon" },
						{ "requires": "($button_type = 'slot_3')", "$icon_texture": "#controller_dpad_left_icon" },
						{ "requires": "($button_type = 'slot_4')", "$icon_texture": "#controller_dpad_down_icon" }
					]
				}
			}
		]
	},



  //---------------------------------------------------------------------------
  // Close button
  //---------------------------------------------------------------------------


	"close_button@origin_common.hori_stack": {
		"size": [60, 18],
		"collection_name": "student_buttons_collection",

		"controls": [
			{
				"content@common.empty_panel": {
					"size": ["100%", "100%"],
					"collection_index": 0,

					"controls": [
						{
							"btn@origin_common.origin_selector_button": {
								"size": ["100%", "100%"],

								"$button_type": "cancel",
								"$visible_binding": "(#student_button_text = #student_button_text)",
								"$button_text_label": "origins.gui.button.cancel",

								"$default_button_texture": "textures/ui/button_borderless_light",
								"$hover_button_texture": "textures/ui/button_borderless_lighthover",
								"$pressed_button_texture": "textures/ui/button_borderless_lightpressed"
							}
						}
					]
				}
			}
		]
	},




	//---------------------------------------------------------------------------
	// Main
	//---------------------------------------------------------------------------


	"ability_selector_root_content@common.empty_panel": {
		"size": ["100%", "100%"],

		"controls": [
			{
				"h_slot0@hitbox_holder": {
					"$button_type": "slot_0",

					"$slot_index": 1,
					"$slot_offset": [0, -52],

					"$slot_tooltip_anchor": "top_middle",
					"$slot_tooltip_offset": [0, -24.25]
				}
			},
			{
				"h_slot1@hitbox_holder": {
					"$button_type": "slot_1",

					"$slot_index": 2,
					"$slot_offset": [50, -10],

					"$slot_tooltip_anchor": "right_middle",
					"$slot_tooltip_offset": [24.25, 0]
				}
			},
			{
				"h_slot2@hitbox_holder": {
					"$button_type": "slot_2",

					"$slot_index": 3,
					"$slot_offset": [31, 46],

					"$slot_tooltip_anchor": "bottom_right",
					"$slot_tooltip_offset": [20, 20]
				}
			},
			{
				"h_slot3@hitbox_holder": {
					"$button_type": "slot_3",

					"$slot_index": 4,
					"$slot_offset": [-31, 46],

					"$slot_tooltip_anchor": "bottom_left",
					"$slot_tooltip_offset": [-20, 20]
				}
			},
			{
				"h_slot4@hitbox_holder": {
					"$button_type": "slot_4",

					"$slot_index": 5,
					"$slot_offset": [-50, -10],

					"$slot_tooltip_anchor": "left_middle",
					"$slot_tooltip_offset": [-24.25, 0]
				}
			},

			{
				"close_button_holder@origin_ability_wheel_npc.close_button": {
					"offset": [0, 92]
				}
			}
		]
	},

	"root@origin_common.binding_condition": {
		"controls": [
			{ "base@origin_ability_wheel_npc.ability_selector_root_content": {} }
		],

		"$condition": "(('%.7s' * #dialogtext) = '_op:abw')"
	}

}
