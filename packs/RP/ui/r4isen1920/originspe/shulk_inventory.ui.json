{
	/* UI developed by r4isen1920 | Under MIT LICENSE */

	"namespace": "origin_shulk_inventory",




	//---------------------------------------------------------------------------
	// Shulk Inventory Grid
	//---------------------------------------------------------------------------


	"shulk_inventory_cell_image": {
		"type": "image",
		"texture": "textures/origins/gui/shulk_inventory/cell_image",
		"layer": 5
	},

	"shulk_inventory_grid_item@common.container_item": {
		"$item_collection_name": "container_items",
		"$background_images": "origin_shulk_inventory.shulk_inventory_cell_image",
		"$item_renderer_panel_size": [16, 16],
		"layer": 5
	},

	"shulk_inventory_grid": {
		"type": "grid",
		"size": [54, "default"],
		"anchor_from": "center",
		"anchor_to": "center",
		"grid_dimensions": [3, 3],
		"grid_item_template": "origin_shulk_inventory.shulk_inventory_grid_item",
		"collection_name": "container_items",
		"layer": 5
	},


	"shulk_inventory_bg": {
		"type": "image",
		"texture": "textures/origins/gui/shulk_inventory/bg",
		"layer": 4
	},




	//---------------------------------------------------------------------------
	// Main Inventory Screen
	//---------------------------------------------------------------------------


	"shulk_and_player_inventory_panels@origin_common.hori_stack": {
		"controls": [
			{
				"shulk_inventory@common.empty_panel": {
					"size": ["100%cm", "100%sm"],

					"controls": [
						{
							"background@origin_shulk_inventory.shulk_inventory_bg": {
								"size": ["100%sm + 12px", "100%sm + 10px"]
							}
						},
						{ "foreground@origin_shulk_inventory.shulk_inventory_grid": {} }
					]
				}
			},
			{
				"center_fold@common.center_fold": {
					"size": [4, "100%sm"]
				}
			},
			{
				//? `ui/ui_common.json` ui templates kinda suck; so we'll just use our own
				"player_inventory@common.empty_panel": {
					"size": ["100%cm", "100%cm"],

					"controls": [
						{
							"background@common.common_panel": {
								"size": ["100%sm + 12px", "100%sm"]
							}
						},
						{
							"foreground@origin_common.verti_stack": {
								"size": [162, "100%c"],
								"layer": 5,

								"controls": [
									{ "top_padding@common.empty_panel": { "size": [1, 12] } },
									{
										"inventory_label@common.section_heading_label": {
          						"text": "container.inventory",
											"layer": 5
										}
									},
									{
										"inventory_grid": {
											"type": "grid",
											"size": [162, 54],
											"grid_dimensions": [ 9, 3 ],
											"grid_item_template": "common.grid_item_for_inventory",
											"collection_name": "inventory_items"
										}
									},
									{ "hotbar_padding@common.empty_panel": { "size": [1, 4] } },
									{
										"hotbar_grid_template": {
											"type": "grid",
											"size": [162, 18],
											"grid_dimensions": [ 9, 1 ],
											"grid_item_template": "common.grid_item_for_hotbar",
											"collection_name": "hotbar_items"
										}
									},
									{ "bottom_padding@common.empty_panel": { "size": [1, 6] } }
								]
							}
						}
					]
				}
			}
		]
	},


	"shulk_inventory_screen@common.empty_panel": {
		"controls": [
			//? more or less the same contents as that of vanilla `ui/chest_screen.json`
			{ "container_gamepad_helpers@common.container_gamepad_helpers": {} },
			{ "selected_item_details_factory@common.selected_item_details_factory": {} },
			{ "item_lock_notification_factory@common.item_lock_notification_factory": {} },
			{
				"root_panel@common.root_panel": {
					"layer": 1,

					"controls": [
						{
							"chest_panel@common.empty_panel": {
								"layer": 5,

								"controls": [
									//* insert our own custom elements
									{ "shulk_and_player_inventory_panels@origin_shulk_inventory.shulk_and_player_inventory_panels": {} },
									{ "inventory_take_progress_icon_button@common.inventory_take_progress_icon_button": {} },
									{ "flying_item_renderer@common.flying_item_renderer": { "layer": 15 } }
								]
							}
						},
						{ "inventory_selected_icon_button@common.inventory_selected_icon_button": {} },
						{ "gamepad_cursor@common.gamepad_cursor_button": {} }
					]
				}
			}
		]
	},




	//---------------------------------------------------------------------------
	// HUD Indicator
	//---------------------------------------------------------------------------


	"shulk_inventory_display_access_icon_fade": {
		"anim_type": "alpha",
		"easing": "linear",
		"from": 1.0,
		"to": 1.0,
		"duration": 1.0,
		"next": "@origin_shulk_inventory.shulk_inventory_display_access_icon_fade_in"
	},

	"shulk_inventory_display_access_icon_fade_in": {
		"anim_type": "alpha",
		"easing": "linear",
		"from": 1.0,
		"to": 0.6,
		"duration": 0.5
	},


	"shulk_inventory_display_access_icon_size": {
		"anim_type": "size",
		"easing": "linear",
		"from": [22, 22],
		"to": [22, 22],
		"duration": 1.0,
		"next": "@origin_shulk_inventory.shulk_inventory_display_access_icon_size_in"
	},

	"shulk_inventory_display_access_icon_size_in": {
		"anim_type": "size",
		"easing": "linear",
		"from": [22, 22],
		"to": [18, 18],
		"duration": 0.1
	},


	"shulk_accessed_inventory_icon": {
		"type": "image",
		"size": "@origin_shulk_inventory.shulk_inventory_display_access_icon_size",
		"offset": [106, 0]
	},


	"shulk_inventory_display_access_icon": {
		"type": "panel",
		"anchor_from": "center",
		"anchor_to": "top_middle",
		"offset": "$set_offset",

		"alpha": "@origin_shulk_inventory.shulk_inventory_display_access_icon_fade",
		"propagate_alpha": true,

		"$set_offset|default": [0, -11],
		"variables": {
			"requires": "($is_android or $is_ios)",
			"$set_offset": [-2, -32]
		},


		"controls": [
			{
				"accessing_player_inventory@origin_shulk_inventory.shulk_accessed_inventory_icon": {
					"texture": "textures/origins/gui/shulk_inventory/icon_player_inventory",
					"ignored": "(not ($var_actionbar_text = '_op:inv.player'))"
				}
			},
			{
				"accessing_shulk_inventory@origin_shulk_inventory.shulk_accessed_inventory_icon": {
					"texture": "textures/origins/gui/shulk_inventory/icon_shulk_inventory",
					"ignored": "(not ($var_actionbar_text = '_op:inv.shulk'))"
				}
			}
		]
	}
}
