{
	/* UI developed by r4isen1920 | Under MIT LICENSE */

	"namespace": "origin_overhead_texts",




	//---------------------------------------------------------------------------
	// Anims
	//---------------------------------------------------------------------------


	"overhead_text_accent_in": {
		"anim_type": "alpha",
		"easing": "in_quad",
		"duration": 0.5,
		"from": 0.0,
		"to": 1.0,
		"next": "@origin_overhead_texts.overhead_text_accent_out"
	},
	"overhead_text_accent_out": {
		"anim_type": "alpha",
		"easing": "linear",
		"duration": 1.0,
		"from": 1.0,
		"to": 0.0
	},

	"overhead_texts_destroy_1": {
		"anim_type": "wait",
		"duration": 2.4,
		"next": "@origin_overhead_texts.overhead_texts_destroy_2"
	},
	"overhead_texts_destroy_2": {
		"anim_type": "alpha",
		"easing": "linear",
		"duration": 0.25,
		"from": 1.0,
		"to": 0.0,
		"destroy_at_end": "overhead_text"
	},




	//---------------------------------------------------------------------------
	// Label
	//---------------------------------------------------------------------------


	"label_element": {
		"type": "label",
		"localize": true,
		"shadow": true,
		"layer": 1
	},

	"overhead_text@common.empty_panel": {
		"$overhead_text|default": "text",
		"$overhead_text_accent|default": "$f_color_format",
		"$overhead_text_font|default": "default",
		"$overhead_text_scale|default": 1.25,


		"anchor_from": "top_middle",
		"anchor_to": "top_middle",
		"size": ["100%c", "100%c"],
		"offset": [0, "12.5%"],

		"alpha": "@origin_overhead_texts.overhead_texts_destroy_1",
		"propagate_alpha": true,

		"$hud_effect_layer": 30,
		"layer": "$hud_effect_layer",

		"controls": [
			{
				"dialogue_texts": {
					"type": "image",
					"size": ["100%cm + 4px", "100%cm + 2px"],
					"texture": "textures/origins/gui/black",

					"alpha": 0.4,
					"propagate_alpha": false,

					"layer": "$hud_effect_layer",

					"controls": [
						{
							"dialogue_text_main@origin_overhead_texts.label_element": {
								"text": "$overhead_text",
								"font_type": "$overhead_text_font",
								"font_scale_factor": "$overhead_text_scale",
								"layer": "$hud_effect_layer"
							}
						},
						{
							"dialogue_text_accent@origin_overhead_texts.label_element": {
								"text": "$overhead_text",
								"font_type": "$overhead_text_font",
								"font_scale_factor": "$overhead_text_scale",
								"color": "$overhead_text_accent",
								"alpha": "@origin_overhead_texts.overhead_text_accent_in",
								"layer": "($hud_effect_layer + 1)"
							}
						}
					]
				}
			}
		]
	},




	//---------------------------------------------------------------------------
	// Main
	//---------------------------------------------------------------------------


	"root@common.empty_panel": {
		"size": ["100%", "100%"],

		"controls": [
			{
				"base@overhead_text": {
					"$overhead_text": "($var_actionbar_text - '_op:overhead_text.')",
					"$overhead_text_accent": "$d_color_format"
				}
			}
		],

		"ignored": "(not ('%.18s' * $var_actionbar_text = '_op:overhead_text.'))"
	}

}
