{
	/* UI developed by r4isen1920 | Under MIT LICENSE */

	"namespace": "origin_common",


  //---------------------------------------------------------------------------
  // Anims
  //---------------------------------------------------------------------------


	"anim_uv_asesprite": {
		"anim_type": "aseprite_flip_book",
		"initial_uv": [0, 0]
	},

	"anim_uv_flipbook": {
		"anim_type": "flip_book",
		"easing": "linear",
		"frame_count": "$max_frame",
		"frame_step": "$frame_step",
		"fps": "$fps",
		"reversible": "$reversible"
	},

	"anim_alpha": {
		"$easing_alpha|default": "linear",
		"$from_alpha|default": 1.0,
		"$to_alpha|default": 1.0,
		"$duration_alpha|default": 1.0,

		"anim_type": "alpha",
		"easing": "$easing_alpha",
		"from": "$from_alpha",
		"to": "$to_alpha",
		"duration": "($duration_alpha * $r4ui_anim_scale)"
	},
	"anim_alpha_delay@anim_alpha": {
		"$duration_delay_alpha|default": 0.0,

		"to": "$from_alpha",
		"duration": "($duration_delay_alpha * $r4ui_anim_scale)",
		"next": "@origin_common.anim_alpha"
	},

	"anim_size": {
		"anim_type": "size",
		"easing": "$easing_size",
		"from": "$from_size",
		"to": "$to_size",
		"duration": "($duration_size * $r4ui_anim_scale)"
	},
	"anim_size_delay@anim_size": {
		"$duration_delay_size|default": 0.0,

		"to": "$from_size",
		"duration": "($duration_delay_size * $r4ui_anim_scale)",
		"next": "@origin_common.anim_size"
	},

	"anim_offset": {
		"$easing_offset|default": "linear",
		"$from_offset|default": [0, 0],
		"$to_offset|default": [0, 0],
		"$duration_offset|default": 1.0,

		"anim_type": "offset",
		"easing": "$easing_offset",
		"from": "$from_offset",
		"to": "$to_offset",
		"duration": "($duration_offset * $r4ui_anim_scale)"
	},
	"anim_offset_delay@anim_offset": {
		"$duration_delay_offset|default": 0.0,

		"to": "$from_offset",
		"duration": "($duration_delay_offset * $r4ui_anim_scale)",
		"next": "@origin_common.anim_offset"
	},

	"anim_beat_alpha_01": {
		"anim_type": "alpha",
		"easing": "linear",
		"duration": 0.8,
		"from": 1.0,
		"to": 0.0,
		"next": "@origin_common.anim_beat_alpha_02"
	},
	"anim_beat_alpha_02": {
		"anim_type": "alpha",
		"easing": "linear",
		"duration": 0.2,
		"from": 0.0,
		"to": 1.0,
		"next": "@origin_common.anim_beat_alpha_01"
	},

	"anim_beat_size_01": {
		"anim_type": "size",
		"easing": "linear",
		"duration": 0.8,
		"from": [188, 208],
		"to": [186, 206],
		"next": "@origin_common.anim_beat_size_02"
	},
	"anim_beat_size_02": {
		"anim_type": "size",
		"easing": "linear",
		"duration": 0.2,
		"from": [186, 206],
		"to": [188, 208],
		"next": "@origin_common.anim_beat_size_01"
	},

	"sway_right_anim_01": {
		"anim_type": "offset",
		"easing": "linear",
		"duration": 0.125,
		"from": [1.5, 0],
		"to": [0, 0],
		"next": "@origin_common.sway_right_anim_02"
	},
	"sway_right_anim_02": {
		"anim_type": "offset",
		"easing": "linear",
		"duration": 0.25,
		"from": [0, 0],
		"to": [-1.5, 0],
		"next": "@origin_common.sway_right_anim_03"
	},
	"sway_right_anim_03": {
		"anim_type": "wait",
		"duration": 0.125,
		"next": "@origin_common.sway_right_anim_01"
	},




  //---------------------------------------------------------------------------
  // Labels
  //---------------------------------------------------------------------------


	"text_label": {
		"type": "label",
		"size": ["100%", "default"],
		"shadow": true,
		"localize": true
	},

	"text_description": {
		"type": "image",
		"size": ["100%cm + 2px", "100%c + 2px"],
		"texture": "textures/origins/gui/banners",
		"clips_children": true,
		"alpha": 0.7,

		"$text_body|default": "body",

		"controls": [
			{
				"text_body@origin_common.text_label": {
					"layer": 100,
					"size": ["default", "default"],
					"max_size": ["100px", "default"],
					"text": "$text_body",
					"text_alignment": "left",
					"color": "$f_color_format",
					"localize": true
				}
			}
		]
	},



  //---------------------------------------------------------------------------
  // Images
  //---------------------------------------------------------------------------


	"image_with_text_description": {
		"type": "image",
		"size": ["100%", "100%c - 5px"],
		"texture": "textures/origins/gui/banners",
		"clips_children": true,

		"$image_icon|default": "pack_icon",
		"$text_header|default": "header",
		"$text_body|default": "body",
		"$show_header_underline|default": true,

		"controls": [
			{
				"image_icon": {
					"type": "image",
					"layer": 1,
					"size": [16, 16],
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"offset": [2.5, 4],
					"texture": "$image_icon"
				}
			},
			{
				"text_header@origin_common.text_label": {
					"layer": 100,
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"offset": [20, 4],
					"size": ["default", "default"],
					"text": "$text_header",
					"controls": [
						{
							"custom_underline": {
								"type": "image",
								"size": ["100%", 1],
								"offset": [-0.5, 0],
								"anchor_from": "bottom_left",
								"anchor_to": "bottom_left",
								"texture": "textures/ui/underline",
								"tiled": "x",
								"ignored": "(not $show_header_underline)",
								"layer": 105
							}
						}
					]
				}
			},
			{
				"text_body@origin_common.text_label": {
					"layer": 100,
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"offset": [20, 16],
					"size": ["85%", "default"],
					"text": "$text_body",
					"color": "$7_color_format",
					"localize": true
				}
			}
		]
	},

	"hoverable_image": {
		"type": "image",
		"texture": "$image_texture",
		"size": "$hover_size",
		"layer": "$panel_base_layer",
		"alpha": "$image_texture_alpha",
		"propagate_alpha": false,

		"$image_texture|default": "pack_icon",
		"$image_texture_alpha|default": 1.0,

		"$hover_text|default": "hover_text",
		"$hover_text_color|default": "$f_color_format",
		"$hover_image_border|default": "disabled",

		"$hover_size|default": ["100%", "100%"],
		"$hover_offset|default": [8, -20],

		"$panel_base_layer|default": 150,

		"controls": [
			{
				"hover_panel@common.button": {
					"size": "$hover_size",
					"$pressed_button_name": "unset",
					"sound_volume": 0.0,
					"layer": "$panel_base_layer",
					"controls": [
						{
							"hover@common.empty_panel": {
								"size": "$hover_size",
								"layer": "$panel_base_layer",
								"controls": [
									{
										"hover_text_image": {
											//* "ignored": true,

											"type": "image",
											"allow_clipping": false,
											"texture": "textures/ui/purpleBorder",
											"size": ["100%c + 9px", "100%c + 8px"],
											"anchor_from": "left_middle",
											"anchor_to": "left_middle",
											"offset": "$hover_offset",
											"layer": "($panel_base_layer + 1)",
											"controls": [
												{
													"hover_text_label": {
														"type": "label",
														"anchor_from": "top_left",
														"anchor_to": "top_left",
														"size": ["default", "default"],
														"max_size": ["145px", "default"],
														"offset": [4, 3],
														"text": "$hover_text",
														"color": "$hover_text_color",
														"localize": true,
														"layer": "($panel_base_layer + 2)"
													}
												}
											]
										}
									},

									{
										"hover_text_renderer": {
											"ignored": true, //* for now */

											"type": "custom",
											"renderer": "hover_text_renderer",

											"allow_clipping": false,
											"layer": "($panel_base_layer + 2)",

											"property_bag": {
												"#hover_text": "$hover_text"
											}
										}
									},

									{
										"hover_image_border": {
											"type": "image",
											"size": "$hover_size",
											"texture": "$hover_image_border",
											"alpha": 1.0,
											"layer": "$panel_base_layer",
											"ignored": "($hover_image_border = 'disabled')"
										}
									}
								]
							}
						}
					]
				}
			}
		]
	},




  //---------------------------------------------------------------------------
  // Scroll Box
  //---------------------------------------------------------------------------

	"scroll_box_active@common.empty_panel": {
		"size": ["100%", "100%"],

		"controls": [
			{
				"scroll_box_handle": {
					"type": "image",
					"texture": "textures/ui/ScrollBox",
					"anchor_from": "top_left",
					"anchor_to": "top_left",

					"layer": 1,

					"controls": [
						{
							"scroll_box_grip": {
								"type": "image",
								"texture": "textures/origins/gui/scroll_box_grip",
								"size": ["90%", "90%"],
								"offset": [-0.1, 0],

								"layer": 1
							}
						}
					]
				}
			}
		]
	},

	"scrolling_panel@common.scrolling_panel": {
		"$scroll_track_image_control": "common.empty_panel",
		"$scroll_box_mouse_image_control": "$scroll_box_image_control",
		"$scroll_box_touch_image_control": "$scroll_box_image_control",

		"controls": [
			{
				"scroll_base@origin_common.scrolling_panel_base": {
					"size": "$scrolling_pane_size",
					"offset": "$scrolling_pane_offset"
				}
			}
		]
	},

	"scrolling_panel_base@common.scrolling_panel_base": {
		"controls": [
			{
				"scroll_view@common.scroll_view_control": {
					"size": "$scrolling_pane_size",

					"controls": [
						{
							"hori@origin_common.hori_stack": {
								"anchor_to": "top_left",
								"anchor_from": "top_left",
								"size": "$scrolling_pane_size",

								"clips_children": true,

								"$view_port_size|default": ["100%c", "100%c"],

								"controls": [
									{ "viewport@origin_common.viewport": {} },
									{ "bar_and_track@origin_common.bar_and_track": {} }
								]
							}
						}
					]
				}
			}
		]
	},

	"viewport@common.scroll_background_and_viewport": {
		"size": "$scroll_view_port_size",

		"controls": [
			{
				"scrolling_view_port@common.empty_panel": {					
					"anchor_from": "top_left",
					"anchor_to": "top_left",
					"size": "$scroll_view_port_size",
					"offset": "$scroll_view_port_offset",

					"clips_children": true,

					"controls": [
						{
							"scrolling_content@$scrolling_content": {
								"$scrolling_content_anchor_from|default": "top_left",
								"$scrolling_content_anchor_to|default": "top_left",
								"anchor_from": "$scrolling_content_anchor_from",
								"anchor_to": "$scrolling_content_anchor_to",

								"layer": 2
							}
						}
					]
				}
			}
		]
	},

	"bar_and_track@common.scroll_bar_and_track": {
		"size": "$scroll_bar_and_track_size",

		"controls": [
			{
				"track@common.scrollbar_track": {
					"anchor_from": "center",
					"anchor_to": "center",

					"layer": 20
				}
			},
			{
				"scroll_box@common.scroll_box": {
					"anchor_from": "center",
					"anchor_to": "center",

					"layer": 25
				}
			}
		]
	},




  //---------------------------------------------------------------------------
  // Buttons
  //---------------------------------------------------------------------------

	"empty_button@common.button": {
		"sound_volume": 0.0,
		"$pressed_button_name": "unset"
	},




  //---------------------------------------------------------------------------
  // Panels
  //---------------------------------------------------------------------------


	"stack_panel": {
		"type": "stack_panel",
		"size": ["100%c", "100%c"]
	},
	"hori_stack@stack_panel": {
		"orientation": "horizontal",
		"size": ["100%c", "100%cm"]
	},
	"verti_stack@stack_panel": {
		"orientation": "vertical",
		"size": ["100%cm", "100%c"]
	},

	"factory_condition@hori_stack": {
		"size": ["100%", "100%"],

		"layer": 3,

		"collection_name": "($target_name + '_collection')",
		"factory": {
			"name": "($target_name + '_factory')",
			"control_name": "$target_control"
		},

		"bindings": [
			{
				"binding_name": "#title_text",
				"binding_type": "global"
			},
			{
				"binding_name": "#dialogtext",
				"binding_type": "global"
			},
			{
				"binding_type": "view",
				"source_property_name": "$condition",
				"target_property_name": "#collection_length"
			}
		]
	},

	"origin_picker_window_template@common_dialogs.main_panel_no_title_no_buttons": {
		"anchor_from": "center",
		"anchor_to": "center",
		"size": [180, 180],

		"$set_offset|default": [0, -4],
		"offset": "$set_offset",

		"$show_close_button": false,
		"$dialog_background_texture": "textures/ui/Banners",
		"clips_children": true,

		"$set_layer|default": 3,
		"layer": "$set_layer"
	}

}
