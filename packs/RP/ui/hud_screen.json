{
	/* UI developed by r4isen1920 | Under MIT LICENSE */

	"hud_title_text": {
		"modifications": [
			{
				"array_name": "bindings",
				"operation": "insert_front",
				"value": [
					{
						"binding_type": "global",
						"binding_name": "#hud_title_text_string",
						"binding_name_override": "#text"
					}
				]
			},
			{
				"array_name": "bindings",
				"operation": "insert_back",
				"value": [
					{
						"binding_type": "view",
						"source_property_name": "(not ('%.4s' * #text = '_op:'))",
						"target_property_name": "#visible"
					}
				]
			}
		]
	},

	"armor_renderer@common.empty_panel": {
		"size": [1, 1],

		"controls": [
			{
				"armor_renderer": {
					"type": "custom",
					"size": [1, 1],
					"renderer": "armor_renderer",
					"layer": 1,
					"bindings": [
						{
							"binding_name": "#is_armor_visible",
							"binding_name_override": "#visible"
						}
					]
				}
			}
		]
	},

	"centered_gui_elements_at_bottom_middle/horse_heart_rend_1": {
		"offset": [80, -51]
	},
	"centered_gui_elements_at_bottom_middle/armor_rend": {
		"bindings": [
			{
				"binding_name": "#is_not_riding",
				"binding_name_override": "#visible"
			}
		]
	},
	"centered_gui_elements_at_bottom_middle/bubbles_rend_1": {
		"offset": [180, -50]
	},

	"custom_hud_title_factory@common.empty_panel": {
		"size": ["100%", "100%"],

		"$title_text|default": " ",
		"$var_title_text": "$title_text",

		"$subtitle_text|default": " ",
		"$var_subtitle_text": "$subtitle_text",

		"controls": [
			{
				"resource_bar_stack@origin_resource_bar.resource_bar_stack": {
					//* Preserve hide-during-screens now that this lives in the
					//* always-drawn bg panel.
					"bindings": [
						{
							"binding_name": "#hud_visible",
							"binding_name_override": "#visible"
						}
					]
				}
			},
			{
				"ability_wheel_stack@origin_ability_wheel.ability_wheel_stack": {}
			}
		]
	},
	"custom_hud_actionbar_factory@common.empty_panel": {
		"size": ["100%", "100%"],

		"$actionbar_text|default": " ",
		"$var_actionbar_text": "$actionbar_text",

		"controls": [
			// { "hud_stuff@origin_hud_stuff.hud_stuff_list": {} }
		]
	},

	"root_panel": {
		"modifications": [
			{
				"array_name": "controls",
				"operation": "insert_front",
				"value": [
					{
						"custom_hud_actionbar_factory": {
							"type": "panel",
							"factory": {
								"name": "hud_actionbar_text_factory",
								"control_ids": {
									"hud_actionbar_text": "controlled_element@hud.custom_hud_actionbar_factory"
								}
							}
						}
					}
				]
			}
		]
	},

	/*
		Bypasses safezone/visibility changes and draws above other screens (incl.
		the NPC input screen) so the ability wheel can float over the HUD. The
		title-controlled element lives here; the resource bar inside is gated by
		#hud_visible to keep its normal hide-during-screens behavior.
	*/
	"root_panel_bg@common.empty_panel": {
		"size": ["100%", "100%"],

		"controls": [
			{
				"custom_hud_title_factory": {
					"type": "panel",
					"factory": {
						"name": "hud_title_text_factory",
						"control_ids": {
							"hud_title_text": "controlled_element@hud.custom_hud_title_factory"
						}
					}
				}
			}
		]
	},

	"hud_screen@common.base_screen": {
		"$screen_content": "hud.hud_content",
		"$screen_bg_content": "hud.root_panel_bg",

		"screen_draws_last": true
	}
}
