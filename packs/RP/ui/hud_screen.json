{
	/* UI developed by r4isen1920 | Under MIT LICENSE */




	//---------------------------------------------------------------------------
	// Vanilla Modifications
	//---------------------------------------------------------------------------


	"hud_title_text": {
		"bindings": [
			{
				"binding_type": "global",
				"binding_name": "#hud_title_text_string"
			},
			{
				"binding_type": "view",
				"source_property_name": "(not ('%.4s' * #hud_title_text_string = '_op:'))",
				"target_property_name": "#visible"
			}
		]
	},


	"chat_panel": {
		"bindings": [
			{
				"binding_type": "global",
				"binding_name": "#hud_title_text_string"
			},
			{
				"binding_type": "view",
				"source_property_name": "('%.4s' * #hud_title_text_string = '_op:')",
				"target_property_name": "#is_addon_payload"
			},
			{
				"binding_type": "view",
				"source_property_name": "('%.17s' * #hud_title_text_string = '_op:resource_bar.')",
				"target_property_name": "#is_resource_bar_payload"
			},
			{
				"binding_type": "view",
				"source_property_name": "((not #is_addon_payload) or #is_resource_bar_payload)",
				"target_property_name": "#visible"
			}
		]
	},


	"subtitle_panel": {
		"bindings": [
			{
				"binding_type": "global",
				"binding_name": "#hud_title_text_string"
			},
			{
				"binding_type": "view",
				"source_property_name": "('%.4s' * #hud_title_text_string = '_op:')",
				"target_property_name": "#is_addon_payload"
			},
			{
				"binding_type": "view",
				"source_property_name": "('%.17s' * #hud_title_text_string = '_op:resource_bar.')",
				"target_property_name": "#is_resource_bar_payload"
			},
			{
				"binding_type": "view",
				"source_property_name": "((not #is_addon_payload) or #is_resource_bar_payload)",
				"target_property_name": "#visible"
			}
		]
	},


	"armor_renderer@common.empty_panel": {
		"size": [1, 1],

		"controls": [
			{
				"armor_renderer": {
					"type": "custom",
					"size": [1, 1],
					"renderer": "armor_renderer",
					"layer": 1,
					"bindings": [
						{
							"binding_name": "#is_armor_visible",
							"binding_name_override": "#visible"
						}
					]
				}
			}
		]
	},


	"centered_gui_elements_at_bottom_middle/horse_heart_rend_1": {
		"offset": [80, -51]
	},
	"centered_gui_elements_at_bottom_middle/armor_rend": {
		"bindings": [
			{
				"binding_name": "#is_not_riding",
				"binding_name_override": "#visible"
			}
		]
	},
	"centered_gui_elements_at_bottom_middle/bubbles_rend_1": {
		"offset": [180, -50]
	},


	"custom_hud_title_factory@common.empty_panel": {
		"size": ["100%", "100%"],

		"$title_text|default": " ",
		"$var_title_text": "$title_text",

		"$subtitle_text|default": " ",
		"$var_subtitle_text": "$subtitle_text",

		"controls": [
			{
				"resource_bar@origin_resource_bar.root": {
					"bindings": [
						{
							"binding_name": "#hud_visible",
							"binding_name_override": "#visible"
						}
					]
				}
			},
			{ "ability_wheel@origin_ability_wheel_hud.root": {} },
			{ "picker_screen@origin_picker_screen_hud.root": {} }
		]
	},
	"custom_hud_actionbar_factory@common.empty_panel": {
		"size": ["100%", "100%"],

		"$actionbar_text|default": " ",
		"$var_actionbar_text": "$actionbar_text",

		"controls": [
			// { "hud_stuff@origin_hud_stuff.hud_stuff_list": {} }
		]
	},




	//---------------------------------------------------------------------------
	// Main
	//---------------------------------------------------------------------------


	"root_panel": {
		"modifications": [
			{
				"array_name": "controls",
				"operation": "insert_front",

				"value": [
					{
						"custom_hud_actionbar_factory@common.empty_panel": {
							"factory": {
								"name": "hud_actionbar_text_factory",
								"control_ids": {
									"hud_actionbar_text": "controlled_element@hud.custom_hud_actionbar_factory"
								}
							}
						}
					}
				]
			}
		]
	},

	"root_panel_bg@common.empty_panel": {
		"size": ["100%", "100%"],

		"controls": [
			{
				"custom_hud_title_factory@common.empty_panel": {
					"factory": {
						"name": "hud_title_text_factory",
						"control_ids": {
							"hud_title_text": "controlled_element@hud.custom_hud_title_factory"
						}
					}
				}
			}
		]
	},


	"hud_screen@common.base_screen": {
		"$screen_content": "hud.hud_content",
		"$screen_bg_content": "hud.root_panel_bg",

		"cache_screen": true,
		"screen_draws_last": true,
		"always_accepts_input": true
	}
}
