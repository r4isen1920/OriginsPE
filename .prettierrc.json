{
	"semi": true,
	"singleQuote": true,
	"printWidth": 100,
	"useTabs": true,
	"tabWidth": 4,
	"quoteProps": "as-needed",
	"trailingComma": "none",
	"bracketSameLine": true,
	"overrides": [
		{
			"files": "*.templ",
			"options": {
				"parser": "json"
			}
		},
		{
			"files": "*.modl",
			"options": {
				"parser": "json"
			}
		}
	]
}
